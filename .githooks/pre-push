# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo "  Running full QA suite (make qa)..."
echo ""

if make qa; then
    echo ""
    echo "${PASS} ${GREEN}All pre-push checks passed${RESET}"
else
    echo ""
    echo "${FAIL} ${RED}Pre-push failed${RESET} вЂ” fix issues before pushing"
    echo "  Run: ${BOLD}make qa${RESET} to see details"
    echo "  Use: ${BOLD}git push --no-verify${RESET} to bypass (not recommended)"
    exit 1
fi
