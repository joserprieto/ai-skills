# Slidev Presentation — Local Configuration
#
# Copy to .env.local (git-ignored) and uncomment as needed.
# Priority: make VAR=val > shell env > .env.local > Makefile defaults

# ─── Presentation ──────────────────────────────────────────────────────────
# SLIDES_FILE=slides.md
# SLIDEV_OPEN=true
# SLIDEV_REMOTE=

# ─── Ports ─────────────────────────────────────────────────────────────────
# DEV_PORT=3030
# PREVIEW_PORT=3031

# ─── Export ────────────────────────────────────────────────────────────────
# EXPORT_TIMEOUT=300000
# PDF_OUTPUT=AI-Tooling-Extended-v3.pdf

# ─── Log rotation ─────────────────────────────────────────────────────────
# LOG_MAX_SIZE=10M
# LOG_MAX_FILES=5
